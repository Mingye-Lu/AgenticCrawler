# LLM Provider (claude, openai, codex)
LLM_PROVIDER=claude

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# OpenAI auth method: api_key (default) or oauth (for Codex/ChatGPT subscription)
OPENAI_AUTH_METHOD=api_key

# Models
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
CODEX_MODEL=codex-mini-latest

# Agent settings
MAX_STEPS=50
HEADLESS=true
