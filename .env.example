# acrawl loads a `.env` from the process cwd when you run the binary.
# Copy to `.env` and fill in values (do not commit `.env`).
#
# Default model (no `--model`): `LLM_PROVIDER` picks which `*_MODEL` is used.
# Empty or unset `LLM_PROVIDER` behaves like `claude`.

# claude | openai | codex
LLM_PROVIDER=claude

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# OpenAI-compatible origin when using OpenAI (optional). No trailing /v1 — client appends /v1/chat/completions.
# OPENAI_BASE_URL=https://api.openai.com

# OpenAI auth method: api_key (default) or oauth (for Codex/ChatGPT subscription)
OPENAI_AUTH_METHOD=api_key

# Models (read according to `LLM_PROVIDER`)
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
CODEX_MODEL=codex-mini-latest

# Agent settings
MAX_STEPS=50
HEADLESS=true
